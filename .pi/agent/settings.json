{
  "lastChangelogVersion": "0.74.0",
  "packages": [
    "npm:pi-subagents",
    "npm:pi-rewind",
    "npm:@juicesharp/rpiv-btw",
    "npm:@juicesharp/rpiv-ask-user-question",
    "npm:pi-total-recall",
    "npm:pi-cmux",
    "npm:@ogulcancelik/pi-ghostty-theme-sync",
    "npm:pi-superpowers"
  ],
  "defaultProvider": "xai",
  "defaultModel": "grok-4.20-0309-reasoning",
