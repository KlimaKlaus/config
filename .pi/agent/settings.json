      "reviewer": {
        "model": "xai/grok-4.20-reasoning",
        "thinkingLevel": "high",
        "fallbackModels": [
          "xai/grok-4.3"
        ]
      },
      "scout": {
        "model": "xai/grok-4-1-fast-reasoning",
        "thinkingLevel": "medium",
        "fallbackModels": [
          "xai/grok-4.3"
        ]
      },
      "worker": {
        "model": "xai/grok-4.1-fast-reasoning",
        "thinkingLevel": "medium",
        "fallbackModels": [
          "xai/grok-4.3"
        ]
      }
    }
  },
  "theme": "ghostty-sync-29d3259e",
  "compaction": {
    "enabled": true
  }
