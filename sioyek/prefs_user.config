# ──────────────────────────────────────────────────────────────
# Sioyek PDF Reader — Lucas's config
# Catppuccin Mocha palette. Toggle dark/light: ctrl+i (or menu)
# ──────────────────────────────────────────────────────────────

# ── Light Mode (default) ─────────────────────────────────────
background_color            #f4ede4

# ── Dark Mode (toggle with ctrl+i) ───────────────────────────
default_dark_mode           0
dark_mode_background_color  #1e1e2e
dark_mode_contrast          0.85
# ── Highlights — visible on both light & dark ────────────────
text_highlight_color        #df8e1d
search_highlight_color      #fe640b
link_highlight_color        #209fb5
synctex_highlight_color     #74c7ec
highlight_links             1
should_highlight_unselected_search 1
alphabetic_link_tags         1

# ── Chrome — mid-tone works on both light & dark ─────────────
status_bar_color            #45475a
status_bar_text_color       #cdd6f4
page_separator_color        #f4ede4
page_separator_width        4
show_document_name_in_statusbar 1
show_closest_bookmark_in_statusbar 1

# ── Interaction — keyboard-first workflow ────────────────────
emacs_mode_menus            1
single_click_selects_words  1
wheel_zoom_on_cursor        1

# ── Search ───────────────────────────────────────────────────
search_url_a                https://scholar.google.com/scholar?q=%1
google_scholar_address      https://scholar.google.com/scholar?q=%1
super_fast_search           1
fuzzy_searching             1

# ── Reading Flow ─────────────────────────────────────────────
visual_mark_next_page_fraction  0.85
visual_mark_next_page_threshold 0.5
autocenter_visual_scroll        1
create_table_of_contents_if_not_exists 1
max_created_toc_size             10000
toc_jump_align_top               1

# ── Window — respect Aerospace tiling ────────────────────────
should_launch_new_window    0
