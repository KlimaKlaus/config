{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "threshold": 75,
  },
  "command": {
    "handoff": {
      "description": "Create a handoff document so another agent can continue the work",
      "template": "Run the handoff skill. Create a handoff document for the next session. Focus: {{input}}"
    },
    "grill-me": {
      "description": "Stress-test a plan or design by being interviewed relentlessly",
      "template": "Run the grill-me skill. Grill me on: {{input}}"
    }
  },
  "agent": {
  },
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "skills": {
    "paths": [
      "/Users/lucasfreytorreshanson/Desktop/code/opencode/skills",
      "/Users/lucasfreytorreshanson/Desktop/code/opencode/skills/superpowers@git+https:/github.com/obra/superpowers.git/node_modules/superpowers/skills",
      "/Users/lucasfreytorreshanson/Desktop/code/config/opencode/skills"
    ]
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "bunx", "-y", "@playwright/mcp@latest"
      ]
    }
  }
}
